# EEC Quora Bot Configuration
# Copy this file to .env and fill in your values

# Claude API key for answer generation
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Database (SQLite by default, can use PostgreSQL URI)
DATABASE_URL=sqlite+aiosqlite:///data/qbot.db

# Dashboard settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=change-this-to-a-random-string

# Proxy configuration (optional, recommended for production)
# Format: http://user:pass@host:port
PROXY_URL=

# Discovery settings
DISCOVERY_INTERVAL_MINUTES=60
MAX_QUESTIONS_PER_RUN=50

# Posting settings
MAX_POSTS_PER_ACCOUNT_PER_DAY=3
MIN_DELAY_BETWEEN_POSTS_SECONDS=1800
MAX_DELAY_BETWEEN_POSTS_SECONDS=7200

# Logging
LOG_LEVEL=INFO
